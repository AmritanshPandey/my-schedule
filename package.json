{
  "name": "my-schedule",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "copy-pdf-worker": "node scripts/copy-pdf-worker.mjs",
    "predev": "node scripts/copy-pdf-worker.mjs",
    "dev": "next dev",
    "test": "node --experimental-strip-types --test tests/*.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "prebuild": "node scripts/copy-pdf-worker.mjs",
    "build": "NEXT_PUBLIC_APP_VERSION=\"$(node -p \"require('./package.json').version\")\" NEXT_PUBLIC_BUILD_ID=\"$(git rev-parse --short HEAD 2>/dev/null || echo dev)\" NEXT_PUBLIC_BUILD_TIME=\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\" next build",
    "postbuild": "node scripts/inject-precache.mjs",
    "start": "next start"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@huggingface/transformers": "^4.2.0",
    "@tabler/icons-react": "^3.41.1",
    "@tiptap/extension-color": "^3.26.1",
    "@tiptap/extension-placeholder": "^3.26.1",
    "@tiptap/extension-table": "^3.26.1",
    "@tiptap/extension-table-cell": "^3.26.1",
    "@tiptap/extension-table-header": "^3.26.1",
    "@tiptap/extension-table-row": "^3.26.1",
    "@tiptap/extension-task-item": "^3.26.1",
    "@tiptap/extension-task-list": "^3.26.1",
    "@tiptap/extension-text-style": "^3.26.1",
    "@tiptap/react": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "clsx": "^2.1.1",
    "firebase": "^12.13.0",
    "framer-motion": "^12.38.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
